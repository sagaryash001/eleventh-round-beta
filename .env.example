# ═════════════════════════════════════════════════════════════════════════════
# Eleventh Round — Environment Configuration
#
# Copy this file to `.env` (project root) and `.env` is also read by the
# Express server at `server/index.js`. Never commit your real `.env`.
#
# Sections are organized by phase. You only need to fill in keys for the
# integrations you've actually connected. Anything left blank will cause the
# matching route/feature to gracefully degrade (or be disabled) at boot.
# ═════════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
LOG_LEVEL=info                            # trace | debug | info | warn | error

# ── PostgreSQL connection pool ───────────────────────────────────────────────
# Use the Supabase pooler URL (recommended) or direct URL.
# Supabase dashboard → Project Settings → Database → Connection string
# Pooler (Supavisor, transaction mode — best for Render):
#   postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Direct (for migrations / long-running queries):
#   postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL=                              # TODO: paste pooler URL here
PG_POOL_MAX=15                             # max simultaneous PG connections (default 15)
PG_IDLE_MS=10000                           # close idle connections after 10s
PG_CONN_MS=5000                            # fail fast if no connection available in 5s

# ── Supabase (Phase 1) ───────────────────────────────────────────────────────
# Create a project at https://supabase.com/dashboard → copy from
# Project Settings → API. The service role key bypasses RLS — keep it
# SERVER-ONLY. Never prefix it with VITE_.
SUPABASE_URL=                              # TODO: https://xxxxxxxx.supabase.co
SUPABASE_ANON_KEY=                         # TODO: safe to ship to client
SUPABASE_SERVICE_ROLE_KEY=                 # TODO: SERVER-ONLY. Never expose.
SUPABASE_JWT_SECRET=                       # TODO: Project Settings → API → JWT Secret

# Frontend mirrors (Vite reads only VITE_* prefixed vars)
VITE_SUPABASE_URL=                         # TODO: same as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=                    # TODO: same as SUPABASE_ANON_KEY

# ── Email / SMTP ─────────────────────────────────────────────────────────────
# Any SMTP provider works. For Gmail, use an App Password (not your login password).
# Google: myaccount.google.com → Security → 2FA → App passwords → Mail
EMAIL_HOST=smtp.gmail.com                  # or smtp.office365.com, mail.privateemail.com, etc.
EMAIL_PORT=465                             # 465 (SSL) or 587 (STARTTLS)
EMAIL_SECURE=true                          # true for port 465, false for 587
EMAIL_USER=                                # TODO: your sending email address
EMAIL_PASS=                                # TODO: app password (NOT your login password)
FROM_EMAIL=contact@eleventh-rnd.us
TEAM_NOTIFY_EMAIL=contact@eleventh-rnd.us  # Leads + overdue alerts land here

# ── Stripe (Phase 3) ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys (test mode first)
STRIPE_SECRET_KEY=                         # TODO: sk_test_... or sk_live_...
STRIPE_WEBHOOK_SECRET=                     # TODO: whsec_... (from `stripe listen` or dashboard webhook)
STRIPE_PRICE_MEMBERSHIP_MONTHLY=           # TODO: price_... (create in Stripe → Products)
STRIPE_PRICE_MEMBERSHIP_ANNUAL=            # TODO: price_...
# Publishable key for the frontend (safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=               # TODO: pk_test_... or pk_live_...

# ── Calendly (Phase 4) ───────────────────────────────────────────────────────
# Get a PAT from https://calendly.com/integrations/api_webhooks
CALENDLY_PERSONAL_ACCESS_TOKEN=            # TODO: eyJraWQiOi...
CALENDLY_WEBHOOK_SIGNING_KEY=              # TODO: generated when you register the webhook
CALENDLY_ORGANIZATION_URI=                 # TODO: https://api.calendly.com/organizations/<uuid>
CALENDLY_EVENT_URL=https://calendly.com/the-eleventh-round/mentorship   # TODO: confirm exact slug

# ── Shopify (Phase 5) ────────────────────────────────────────────────────────
# Just storefront URL is enough for click-through. Storefront token only
# needed if we render product cards server-side.
SHOPIFY_STORE_URL=                         # TODO: https://eleventh-round.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=                  # OPTIONAL — only for server-rendered product cards

# ── Spotify (Phase 5) ────────────────────────────────────────────────────────
# Show ID is the part after /show/ in the Spotify URL.
SPOTIFY_SHOW_ID=                           # TODO: e.g. 4rOoJ6Egrf8K2IrywzwOMk
SPOTIFY_CLIENT_ID=                         # OPTIONAL — for Web API access
SPOTIFY_CLIENT_SECRET=                     # OPTIONAL — server-only

# ── Google Analytics 4 (Phase 7) ─────────────────────────────────────────────
# Measurement ID is safe to expose. API secret is server-only (Measurement
# Protocol for backend events like Stripe payment_succeeded).
VITE_GA4_MEASUREMENT_ID=                   # TODO: G-XXXXXXXXXX
GA4_API_SECRET=                            # TODO: server-only

# ── Obligations / Overdue Job (Phase 6) ──────────────────────────────────────
# How often the backend scans for overdue obligations and broadcasts on
# the Supabase Realtime channel `obligations`.
OVERDUE_SCAN_INTERVAL_MIN=15

# ── Rate Limits ──────────────────────────────────────────────────────────────
RATE_LIMIT_PUBLIC_PER_MIN=20               # /leads, /auth/* etc.
RATE_LIMIT_WEBHOOK_PER_MIN=120             # Stripe/Calendly webhooks
