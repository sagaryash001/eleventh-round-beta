ld.id} className=\"absolute\" style={{left:childXs[ci],top:CHILD_Y-CHILD_SIZE/2,transform:'translateX(-50%)',zIndex:10,animation:`nodeAppear 0.32s cubic-bezier(.25,.46,.45,.94) ${ci*0.05}s both`}}\n              onMouseEnter={()=>{ cancelLeave(); setHovChild(child.id) }} onMouseLeave={()=>{ setHovChild(null); scheduleLeave() }}>\n              <CircleNode\n                label={child.label} point={child.point}\n                active={false} hovered={hovChild===child.id}\n                onEnter={()=>setHovChild(child.id)} onLeave={()=>setHovChild(null)}\n                onClick={()=>setDetail({node:child,color:openData.color})}\n                size={CHILD_SIZE} color={openData.color}/>\n            </div>\n          ))\n        })", "is_member_call": false, "source_file": "/Users/yashsagar/Downloads/er-app/src/components/ProductsCarousel.tsx", "source_location": "L273"}, {"caller_nid": "components_productscarousel_productssection", "callee": "map", "is_member_call": true, "source_file": "/Users/yashsagar/Downloads/er-app/src/components/ProductsCarousel.tsx", "source_location": "L307"}, {"caller_nid": "components_productscarousel_productssection", "callee": "map", "is_member_call": true, "source_file": "/Users/yashsagar/Downloads/er-app/src/components/ProductsCarousel.tsx", "source_location": "L348"}, {"caller_nid": "components_productscarousel_productssection", "callee": "map", "is_member_call": true, "source_file": "/Users/yashsagar/Downloads/er-app/src/components/ProductsCarousel.tsx", "source_location": "L361"}]}